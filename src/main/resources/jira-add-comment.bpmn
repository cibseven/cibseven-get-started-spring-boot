    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_11vqbi6" sourceRef="Activity_0uhe268" targetRef="Event_190tx7w" />
    <bpmn:sequenceFlow id="Flow_0t49bwy" sourceRef="Activity_1x19ugu" targetRef="Activity_1iif64i" />
    <bpmn:scriptTask id="Activity_1x19ugu" name="create comment" scriptFormat="groovy">
      <bpmn:incoming>Flow_1djlhph</bpmn:incoming>
      <bpmn:outgoing>Flow_0t49bwy</bpmn:outgoing>
      <bpmn:script>def commentJson = "{\"update\":{\"comment\":[{\"add\":{\"body\":\"${commentBody}\"}}]}}";
execution.setVariable("out_commentJson", commentJson);
execution.setVariable("out_status", "sick leave");</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:sequenceFlow id="Flow_1oc9s3o" sourceRef="Activity_1iif64i" targetRef="Activity_015zboq" />
    <bpmn:userTask id="Activity_1iif64i" camunda:assignee="${initiator}">
      <bpmn:incoming>Flow_0t49bwy</bpmn:incoming>
      <bpmn:outgoing>Flow_1oc9s3o</bpmn:outgoing>
    </bpmn:userTask>
  </bpmn:process>
