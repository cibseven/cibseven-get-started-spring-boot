  <bpmn:process id="mcpProcess_jira-add-comment-krank" name="Add Comment to KRANK Jira Task" isExecutable="true" camunda:historyTimeToLive="996">
    <bpmn:documentation>This process adds a comment to a Jira issue (KRANK-5735). It creates the comment JSON, optionally lets the initiator review it, sends it via a REST PUT request to Jira, and then stops for final confirmation. The desired comment to add should be set as commentBody input variable</bpmn:documentation>
    <bpmn:startEvent id="StartEvent_1" camunda:initiator="initiator">
      <bpmn:outgoing>Flow_1djlhph</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_1djlhph" sourceRef="StartEvent_1" targetRef="Activity_1x19ugu" />
    <bpmn:serviceTask id="Activity_015zboq" name="Request senden" camunda:modelerTemplate="rest-3.0.3" camunda:class="de.cib.cibflow.template.rest.SendRestRequestTask">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="queryParameters" />
          <camunda:inputParameter name="fileBody" />
          <camunda:inputParameter name="xWwwFormUrlencodedBodyParameters" />
          <camunda:inputParameter name="certificate" />
          <camunda:inputParameter name="certificatePassword" />
          <camunda:inputParameter name="throwBpmnErrorOnFailure">true</camunda:inputParameter>
          <camunda:inputParameter name="returnType">void</camunda:inputParameter>
          <camunda:inputParameter name="resultVariableNameStatusCode">statusCode</camunda:inputParameter>
          <camunda:inputParameter name="resultVariableName">response</camunda:inputParameter>
          <camunda:inputParameter name="requestHeaders">Content-Type=application/json
Authorization=Basic c3lzLWppcmE6OVJxbTcvInBXb0RYTi9tYlRTTQ==</camunda:inputParameter>
          <camunda:inputParameter name="url">https://jiraupdatetest.cib.de/rest/api/2/issue/KRANK-5735</camunda:inputParameter>
          <camunda:inputParameter name="requestType">PUT</camunda:inputParameter>
          <camunda:inputParameter name="jsonBodyVariableName">commentJson</camunda:inputParameter>
        </camunda:inputOutput>
        <camunda:properties>
          <camunda:property name="documentation" value="Mit diesem Element-Template kann ein beliebiger Get-Request abgesetzt werden." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1oc9s3o</bpmn:incoming>
      <bpmn:outgoing>Flow_0f8pl5u</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0f8pl5u" sourceRef="Activity_015zboq" targetRef="Activity_0uhe268" />
    <bpmn:userTask id="Activity_0uhe268" name="STOP" camunda:assignee="${initiator}">
